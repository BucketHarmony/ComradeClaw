# Comrade Claw Environment Configuration
# Copy this file to .env and fill in your values

# === LLM ===
# ANTHROPIC_API_KEY is read from system environment if not set here
# ANTHROPIC_API_KEY=sk-ant-...

# === Discord (Operator Channel) ===
DISCORD_BOT_TOKEN=
OPERATOR_DISCORD_USER_ID=
DISCORD_GUILD_ID=

# === Bluesky (Broadcast) ===
BLUESKY_HANDLE=comradeclaw.bsky.social
BLUESKY_APP_PASSWORD=

# === Gmail (Notifications & Outreach) ===
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
OPERATOR_EMAIL=

# === Local LLM Fallback ===
OLLAMA_BASE_URL=http://host.docker.internal:11434

# === Timezone ===
TZ=America/Detroit
