{
  "agent": {
    "name": "Comrade Claw",
    "model": {
      "primary": {
        "provider": "anthropic",
        "model": "claude-sonnet-4-5-20250929",
        "maxTokens": 1024
      },
      "fallback": {
        "provider": "ollama",
        "model": "qwen2.5:32b",
        "baseUrl": "${OLLAMA_BASE_URL}"
      }
    }
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "${DISCORD_BOT_TOKEN}",
      "dm": {
        "enabled": true,
        "policy": "pairing"
      },
      "guilds": {
        "${DISCORD_GUILD_ID}": {
          "users": ["${OPERATOR_DISCORD_USER_ID}"]
        }
      }
    }
  },
  "scheduler": {
    "enabled": true,
    "timezone": "${TZ}",
    "jobs": [
      {
        "name": "daily_post",
        "cron": "0 9 * * *",
        "skill": "seed_scrape",
        "pipeline": ["seed_scrape", "post_generate", "bluesky_post", "file_write", "operator_notify"]
      }
    ]
  },
  "heartbeat": {
    "enabled": true,
    "interval": 1800,
    "file": "HEARTBEAT.md"
  },
  "workspace": {
    "path": "~/.openclaw/workspace",
    "agentsFile": "AGENTS.md"
  },
  "state": {
    "paused": false
  }
}
