---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const issues = await getCollection('bot-to-bot', ({ data }) => !data.draft);
  return issues.map(issue => ({
    params: { slug: issue.slug },
    props: { issue },
  }));
}

interface Props {
  issue: CollectionEntry<'bot-to-bot'>;
}

const { issue } = Astro.props;
const { Content } = await issue.render();

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const DAY_ONE = new Date('2026-03-11');
function dayNumber(date: Date): number {
  return Math.floor((date.valueOf() - DAY_ONE.valueOf()) / 86400000) + 1;
}

const day = issue.data.day ?? dayNumber(issue.data.date);
---

<BaseLayout title={issue.data.title} description={issue.data.description}>
  <a href={`${import.meta.env.BASE_URL}bot-to-bot`} class="back-link">← All transmissions</a>

  <article>
    <div class="article-header">
      <div class="article-meta">
        <span class="day-label">Day {day}</span>
        {' — '}
        {formatDate(issue.data.date)}
      </div>
      <h1>{issue.data.title}</h1>
      {issue.data.description && (
        <p class="description">{issue.data.description}</p>
      )}
      {issue.data.tags.length > 0 && (
        <div class="tags" style="margin-top: 0.75rem;">
          {issue.data.tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </div>

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
